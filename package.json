    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  },
  "reactDoctor": {
    "rules": {
      "firebase-permissive-rules": "off",
      "low-supply-chain-score": "off",
      "unused-file": "off",
      "cors-cookie-trust-risk": "off",
      "js-flatmap-filter": "off",
      "async-await-in-loop": "off",
      "artifact-baas-authority-surface": "off",
      "unused-dev-dependency": "off",
      "use-lazy-motion": "off",
      "rerender-lazy-ref-init": "off",
      "button-has-type": "off",
      "no-giant-component": "off",
      "prefer-useReducer": "off",
      "rerender-lazy-state-init": "off",
      "server-sequential-independent-await": "off",
      "exhaustive-deps": "off",
      "prefer-use-effect-event": "off",
      "no-scale-from-zero": "off",
      "no-layout-property-animation": "off",
      "control-has-associated-label": "off",
      "no-static-element-interactions": "off",
      "no-array-index-as-key": "off",
      "label-has-associated-control": "off",
      "click-events-have-key-events": "off",
      "no-effect-chain": "off",
      "no-adjust-state-on-prop-change": "off",
      "prefer-module-scope-pure-function": "off",
      "prefer-module-scope-static-value": "off",
      "no-noninteractive-element-interactions": "off",
      "no-derived-state-effect": "off",
      "client-localstorage-no-version": "off",
      "no-event-handler": "off",
      "no-derived-state": "off",
      "no-chain-state-updates": "off",
      "js-set-map-lookups": "off",
      "no-fetch-in-effect": "off",
      "no-effect-event-handler": "off",
      "no-large-animated-blur": "off",
      "jsx-max-depth": "off",
      "js-combine-iterations": "off",
      "no-cascading-set-state": "off",
      "no-initialize-state": "off",
      "rerender-state-only-in-handlers": "off",
      "no-reset-all-state-on-prop-change": "off",
      "iframe-missing-sandbox": "off",
      "no-autofocus": "off",
      "prefer-dynamic-import": "off",
      "rendering-hydration-no-flicker": "off",
      "style-prop-object": "off",
      "no-nested-component-definition": "off",
      "no-prop-callback-in-effect": "off",
      "unused-export": "off",
      "async-parallel": "off",
      "no-usememo-simple-expression": "off",
      "no-permanent-will-change": "off",
      "anchor-has-content": "off",
      "no-inline-prop-on-memo-component": "off",
      "jsx-no-new-function-as-prop": "off"
    }
  }
