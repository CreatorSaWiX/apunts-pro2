rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funció per comprovar si l'usuari és moderador
    function isModerator() {
      return request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderador' || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor');
    }

    // Usuaris
    match /users/{userId} {
      allow read: if true;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
                    && (request.resource.data.role == 'invitat' || request.resource.data.role == 'moderador');
    }

    match /invites/{code} {
      allow read, write: if false;
    }

    // Missatges: permetre llegir els propis missatges, o enviar a qualsevol si estàs autenticat
    match /messages/{document=**} {
      allow read, update, delete: if request.auth != null && resource.data.receiverId == request.auth.uid;
      // Els loguejats poden enviar a tothom. Els anònims NOMÉS poden enviar missatges (Feedback) al teu UID directament.
      allow create: if request.auth != null || request.resource.data.receiverId == 'jV5Y63M77PcqIcOUCpLz76GTYMI3';
    }

    // Solucions i Notificacions: els moderadors fan i desfan la base, però tothom autenticat pot comentar
    match /solutions/{solutionId} {
      allow read: if true;
      allow write: if isModerator();
      
      // Subcol·lecció de comentaris oberta per a tots els autenticats
      match /comments/{commentId} {
        allow read: if true;
        allow create, update: if request.auth != null;
        // Només l'autor original o l'administrador pot esborrar els missatges
        allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isModerator());
      }
    }

    match /notifications/{document=**} {
      allow read, update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isModerator());
      allow create: if request.auth != null;
    }

    // Comunitat
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        // Reaccions i reports: qualsevol autenticat
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'reports']) ||
        // Rank i Pin: només moderadors
        isModerator() ||
        // Propi contingut: l'autor
        (request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content', 'subject', 'type']))
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isModerator());

      match /replies/{replyId} {
        allow read: if true;
        allow create, update: if request.auth != null;
        allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isModerator());
      }
    }

    // Fallback
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false; 
    }
  }
}
